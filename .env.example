# =============================================================================
#  Configuracion del proyecto ProyectoAgenteIAFormacion
#  Copiar como .env y ajustar a tu entorno: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Logging (todos los servicios)
# -----------------------------------------------------------------------------
# Niveles validos: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Rutas locales (host)
# -----------------------------------------------------------------------------
# Carpeta donde estan los PDF/DOCX que el indexador va a procesar
DATA_ROOT=./data/pdfs
# Carpeta raiz donde estan los modelos
MODELS_ROOT=./models
# Subcarpeta del modelo de embeddings (relativa a MODELS_ROOT)
EMBEDDINGS_DIR=all-MiniLM-L6-v2
# Subcarpeta del modelo LLaVA (relativa a MODELS_ROOT)
LLAVA_DIR=llava
# Nombre del fichero GGUF de LLaVA dentro de LLAVA_DIR
LLAVA_MODEL_FILE=ggml-model-q4_k.gguf

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=docs

# -----------------------------------------------------------------------------
# Indexer
# -----------------------------------------------------------------------------
CHUNK_SIZE=280
CHUNK_STRIDE=200
# Chunking estructural (respeta paginas/parrafos). 1 = activo, 0 = chunking plano por palabras.
STRUCTURAL_CHUNKING=1

# -----------------------------------------------------------------------------
# LLaVA service
# -----------------------------------------------------------------------------
LLAVA_N_THREADS=4
LLAVA_N_CTX=1024
LLAVA_N_BATCH=32

# -----------------------------------------------------------------------------
# Chat API
# -----------------------------------------------------------------------------
LLAVA_READ_TIMEOUT=50
LLAVA_RETRIES=1
LLAVA_MAX_TOKENS_CHAT=320
LLAVA_MAX_TOKENS_SUMMARY=220
PROMPT_CHAR_BUDGET=1200
SEARCH_MULTIPLIER=6
# MMR para diversificar candidatos (1.0 = solo relevancia, 0.0 = solo diversidad).
MMR_LAMBDA=0.7
# Permite hasta 2 chunks por doc cuando el segundo score es muy cercano al mejor.
ALLOW_MULTI_CHUNK=true
MULTI_CHUNK_RATIO=0.9
MEMORY_TTL_DAYS=5
MEMORY_MAX_TURNS=8
MEMORY_SUMMARY_TARGET_CHARS=1200
# CORS: usa "*" para entorno de desarrollo o una lista separada por comas:
# p.ej. "http://localhost:7860,http://localhost:3000"
CORS_ORIGINS=*
# Comando shell que dispara una reindexacion. Vacio = endpoint /admin/reindex devuelve 503.
# Ejemplo (si el indexer es un sidecar accesible por la red): ""
REINDEX_COMMAND=

# -----------------------------------------------------------------------------
# UI
# -----------------------------------------------------------------------------
BACKEND_URL=http://chat-api:8000/chat
FILES_PUBLIC_BASE=http://localhost:8000
# Valores por defecto en los sliders de Gradio
UI_DEFAULT_THRESHOLD=0.4
UI_DEFAULT_K=5

# -----------------------------------------------------------------------------
# Limites de recursos en compose (mem_limit / cpus)
# -----------------------------------------------------------------------------
QDRANT_MEM_LIMIT=1g
QDRANT_CPUS=1.0
INDEXER_MEM_LIMIT=1g
INDEXER_CPUS=2.0
LLAVA_MEM_LIMIT=4g
LLAVA_CPUS=2.0
CHAT_API_MEM_LIMIT=1g
CHAT_API_CPUS=1.0
UI_MEM_LIMIT=512m
UI_CPUS=0.5
