FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl libgomp1 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir gradio requests

WORKDIR /app

COPY src/ui/ui_app.py /app/ui_app.py

ENV BACKEND_URL=http://chat-api:8000/chat

EXPOSE 7860

CMD ["python", "/app/ui_app.py"]

